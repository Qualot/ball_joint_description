<?xml version="1.0"?>
<robot name="right">
  <!-- common materials -->
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>


  <!-- Pelvis -->
  <link name="pelvis">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="white"/>
    </visual>
  </link>

  <!-- Femur -->
  <link name="femur">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <!-- <box size="0.05 0.05 0.3"/> -->
        <cylinder length="0.3" radius="0.015"/>
      </geometry>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <!-- Ball joint at hip -->
  <joint name="hip_roll" type="continuous">
    <parent link="pelvis"/>
    <child link="hip_roll_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.3" upper="1.3" effort="50" velocity="1.0"/>
  </joint>

  <link name="hip_roll_link"/>

  <joint name="hip_pitch" type="continuous">
    <parent link="hip_roll_link"/>
    <child link="hip_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.3" upper="0.0" effort="50" velocity="1.0"/>
  </joint>

  <link name="hip_pitch_link"/>

  <joint name="hip_yaw" type="continuous">
    <parent link="hip_pitch_link"/>
    <child link="femur"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.3" upper="1.3" effort="50" velocity="1.0"/>
  </joint>
</robot>
